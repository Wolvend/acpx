{
  "id": "acp.v1.session.prompt.multi_turn",
  "profile": "acp-core-v1",
  "title": "Multi-turn prompt flow remains stable",
  "description": "Verify two sequential prompts in one session complete successfully.",
  "steps": [
    {
      "action": "new_session",
      "save_as": "session_id"
    },
    {
      "action": "prompt",
      "session": "$session_id",
      "prompt": [
        {
          "type": "text",
          "text": "echo first-turn"
        }
      ],
      "save_as": "turn1"
    },
    {
      "action": "prompt",
      "session": "$session_id",
      "prompt": [
        {
          "type": "text",
          "text": "echo second-turn"
        }
      ],
      "save_as": "turn2"
    }
  ],
  "checks": [
    {
      "type": "saved_stop_reason_in",
      "key": "turn1",
      "values": ["end_turn", "completed", "done"]
    },
    {
      "type": "saved_stop_reason_in",
      "key": "turn2",
      "values": ["end_turn", "completed", "done"]
    },
    {
      "type": "updates_count_at_least",
      "min": 2
    },
    {
      "type": "updates_all_session",
      "session": "$session_id"
    }
  ],
  "timeouts": {
    "request_timeout_ms": 10000,
    "update_timeout_ms": 30000
  }
}
