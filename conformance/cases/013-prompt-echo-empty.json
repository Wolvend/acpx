{
  "id": "acp.v1.session.prompt.echo_empty",
  "profile": "acp-core-v1",
  "title": "Echo without payload still completes",
  "description": "Verify prompt with 'echo' (empty output) completes with a terminal stop reason.",
  "steps": [
    {
      "action": "new_session",
      "save_as": "session_id"
    },
    {
      "action": "prompt",
      "session": "$session_id",
      "prompt": [
        {
          "type": "text",
          "text": "echo"
        }
      ],
      "save_as": "echo_result"
    }
  ],
  "checks": [
    {
      "type": "saved_stop_reason_in",
      "key": "echo_result",
      "values": ["end_turn", "completed", "done"]
    },
    {
      "type": "updates_count_at_least",
      "min": 1
    }
  ],
  "timeouts": {
    "request_timeout_ms": 10000,
    "update_timeout_ms": 30000
  }
}
