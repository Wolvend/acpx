{
  "id": "acp.v1.session.prompt.single_turn",
  "profile": "acp-core-v1",
  "title": "Prompt request starts and completes one turn",
  "description": "Verify a valid prompt runs end-to-end and yields updates.",
  "steps": [
    {
      "action": "new_session",
      "save_as": "session_id"
    },
    {
      "action": "prompt",
      "session": "$session_id",
      "prompt": [
        {
          "type": "text",
          "text": "echo ok"
        }
      ],
      "save_as": "prompt_result"
    }
  ],
  "checks": [
    {
      "type": "saved_stop_reason_in",
      "key": "prompt_result",
      "values": ["end_turn", "completed", "done"]
    },
    {
      "type": "updates_count_at_least",
      "min": 1
    }
  ],
  "timeouts": {
    "request_timeout_ms": 10000,
    "update_timeout_ms": 30000
  }
}
