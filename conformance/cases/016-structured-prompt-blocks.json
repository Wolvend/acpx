{
  "id": "acp.v1.session.prompt.structured_blocks",
  "profile": "acp-core-v1",
  "title": "Structured prompt blocks are preserved",
  "description": "Verify non-text ACP content blocks can be sent and observed without flattening errors.",
  "steps": [
    {
      "action": "new_session",
      "save_as": "session_id"
    },
    {
      "action": "prompt",
      "session": "$session_id",
      "prompt": [
        {
          "type": "text",
          "text": "inspect-prompt"
        },
        {
          "type": "resource",
          "resource": {
            "uri": "file:///tmp/conformance-resource.txt",
            "text": "conformance-resource"
          }
        }
      ],
      "save_as": "inspect_prompt_result"
    }
  ],
  "checks": [
    {
      "type": "saved_stop_reason_in",
      "key": "inspect_prompt_result",
      "values": ["end_turn", "completed", "done"]
    },
    {
      "type": "updates_text_includes",
      "text": "\"type\":\"resource\""
    }
  ],
  "timeouts": {
    "request_timeout_ms": 10000,
    "update_timeout_ms": 30000
  }
}
