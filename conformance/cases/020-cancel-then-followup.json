{
  "id": "acp.v1.session.cancel.followup_prompt",
  "profile": "acp-core-v1",
  "title": "Session remains usable after cancellation",
  "description": "Verify a session can continue with a new prompt after a cancelled turn.",
  "steps": [
    {
      "action": "new_session",
      "save_as": "session_id"
    },
    {
      "action": "prompt_background",
      "session": "$session_id",
      "prompt": [
        {
          "type": "text",
          "text": "sleep 5000"
        }
      ],
      "save_as": "bg_prompt"
    },
    {
      "action": "sleep",
      "ms": 100
    },
    {
      "action": "cancel",
      "session": "$session_id"
    },
    {
      "action": "await_background",
      "from": "bg_prompt",
      "save_as": "cancel_result"
    },
    {
      "action": "prompt",
      "session": "$session_id",
      "prompt": [
        {
          "type": "text",
          "text": "echo after-cancel"
        }
      ],
      "save_as": "followup_result"
    }
  ],
  "checks": [
    {
      "type": "saved_stop_reason_in",
      "key": "cancel_result",
      "values": ["cancelled"]
    },
    {
      "type": "saved_stop_reason_in",
      "key": "followup_result",
      "values": ["end_turn", "completed", "done"]
    },
    {
      "type": "updates_text_includes",
      "text": "after-cancel"
    }
  ],
  "timeouts": {
    "request_timeout_ms": 10000,
    "update_timeout_ms": 30000
  }
}
